# Google Apps Script — Script Properties
# These values are NEVER stored in source code.
# Set them once by running Setup > setAllConfig() in the Apps Script editor.
#
# How to set in Apps Script editor:
#   1. Open Extensions > Apps Script
#   2. Open Setup.gs
#   3. Run: setAllConfig()
#      OR go to Project Settings > Script Properties and add manually.

TELEGRAM_TOKEN=your_bot_token_here         # from @BotFather
TELEGRAM_CHAT_ID=your_chat_id_here         # from getTelegramChatId()
